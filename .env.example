# ============================================
# TaxNavigator AI Agent - Environment Variables
# ============================================

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=taxnav_knowledge

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ── Telegram Bot — LIMITED (client-facing, with restrictions) ────
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_WEBHOOK_URL=https://chat.taxnavigator-advice.nl/api/telegram/webhook

# ── Telegram Bot — FULL (professional, no restrictions) ──────────
TELEGRAM_BOT_TOKEN_FULL=
TELEGRAM_WEBHOOK_URL_FULL=https://chat.taxnavigator-advice.nl/api/telegram/webhook-full

# WhatsApp (Twilio)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Bitrix24 (этап 2)
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.nl/rest/1/your-webhook-key/

# App Settings
APP_SECRET_KEY=generate-a-random-secret-key-here
APP_BASE_URL=https://chat.taxnavigator-advice.nl
ALLOWED_ORIGINS=https://taxnavigator-advice.nl,https://www.taxnavigator-advice.nl
LOG_LEVEL=INFO

# Crawler schedule (cron format) - каждый день в 3:00
CRAWLER_SCHEDULE=0 3 * * *
